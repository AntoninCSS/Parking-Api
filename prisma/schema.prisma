generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model logs {
  id         Int       @id @default(autoincrement())
  level      String?   @db.VarChar(50)
  action     String?   @db.VarChar(255)
  message    String?
  user_id    Int?
  meta       Json?
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

model parkings {
  id           Int            @id @default(autoincrement())
  name         String         @db.VarChar(255)
  city         String         @db.VarChar(255)
  capacity     Int            @default(1)
  created_at   DateTime?      @default(now()) @db.Timestamp(6)
  updated_at   DateTime?      @default(now()) @db.Timestamp(6)
  reservations reservations[]
}

model reservations {
  id            Int       @id @default(autoincrement())
  parking_id    Int
  client_name   String    @db.VarChar(255)
  vehicle       String    @db.VarChar(100)
  license_plate String    @db.VarChar(20)
  checkin       DateTime  @db.Timestamp(6)
  checkout      DateTime  @db.Timestamp(6)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)
  parkings      parkings  @relation(fields: [parking_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id            Int       @id @default(autoincrement())
  email         String    @unique @db.VarChar(255)
  password_hash String    @db.VarChar(255)
  role          String?   @default("user") @db.VarChar(50)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  refresh_tokens refresh_tokens[]
}

model refresh_tokens {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token      String   @unique
  created_at DateTime @default(now())

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}